FoamFile
{
    version 2.0;
    format ascii;
    class dictionary;
    object controlDict;
}

application simpleFoam;

startFrom startTime;
startTime 0;

stopAt endTime;
endTime 1000;

deltaT 1;

writeControl timeStep;
writeInterval 100;

purgeWrite 0;

writeFormat ascii;
writePrecision 6;
writeCompression off;

timeFormat general;
timePrecision 6;

runTimeModifiable true;


// 🔥 FORCES BLOCK (FINAL CORRECT)
functions
{
    forces
    {
        type forces;
        libs ("libforces.so");

        patches (cylinder);

        rho rhoInf;
        rhoInf 1.164;

        CofR (1 0 0);

        writeControl timeStep;
        writeInterval 1;

        log yes;
    }
}
